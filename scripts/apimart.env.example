# APIMart 图片生成 API 配置
# 复制本文件为 apimart.env 并填写密钥
# 注意：apimart.env 包含密钥，不要提交到版本控制
# 脚本支持 TOKEN / SK / API_KEY（优先读取 TOKEN）

API_URL: https://api.apimart.ai/v1/images/generations
MODEL: gemini-3-pro-image-preview
TOKEN: <your-apimart-api-key-here>
# SK: <your-apimart-api-key-here>
# API_KEY: <your-apimart-api-key-here>
RESOLUTION: 2K
SIZE: 16:9
N: 1
PAD_URL:
